# Normalise line endings on commit; check out as LF everywhere (macOS build target)
* text=auto eol=lf

# Shell scripts must always be LF
*.sh text eol=lf

# Swift source must always be LF
*.swift text eol=lf

# Markdown, JSON, and CI config — LF
*.md text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary assets — no line-ending conversion
*.png binary
*.jpg binary
*.pdf binary
*.xcassets binary
